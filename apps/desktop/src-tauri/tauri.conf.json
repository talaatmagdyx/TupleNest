{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TupleNest",
  "version": "0.1.0",
  "identifier": "app.tuplenest.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TupleNest",
        "maximized": true,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzNUVENDM0QzhBRUNDMUIKUldRYnpLN0lOTlJldytNbzZZdTUvbTRwZDV3U1l3UHEraGxiRzRwUHVLeXRiUjFvWjhMa1RnUWkK",
      "endpoints": [
        "https://github.com/talaatmagdyx/TupleNest/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "PostgreSQL database IDE",
    "longDescription": "TupleNest is a fast, safety-first PostgreSQL desktop IDE: connections with TLS and SSH tunnels, schema explorer, streaming result grid, transactions, query history, EXPLAIN plans, and live server monitoring.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  }
}
