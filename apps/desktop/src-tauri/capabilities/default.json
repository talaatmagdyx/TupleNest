{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core runtime only. Every TupleNest command is explicitly listed; nothing broad is exposed.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/talaatmagdyx" }, { "url": "https://claude.com" }]
    }
  ]
}
